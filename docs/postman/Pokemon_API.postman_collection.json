    {
      "name": "Pokemon Endpoints",
      "item": [
        {
          "name": "List All Pokemon",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/pokemon",
              "host": ["{{base_url}}"],
              "path": ["api", "pokemon"]
            },
            "description": "Retrieve a list of all available Pokemon. Returns basic information for each Pokemon."
          },
          "response": []

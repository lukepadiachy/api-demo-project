        {
          "name": "List Pokemon with Pagination",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/pokemon?limit=5&offset=10",
              "host": ["{{base_url}}"],
              "path": ["api", "pokemon"],
              "query": [
                {
                  "key": "limit",
                  "value": "5",
                  "description": "Number of results to return"
                },
                {
                  "key": "offset",
                  "value": "10",
                  "description": "Number of results to skip"
                }
              ]
            },
            "description": "Retrieve a paginated list of Pokemon. Use limit to control how many results to return and offset to skip results."
          },
          "response": []
        },
        {
